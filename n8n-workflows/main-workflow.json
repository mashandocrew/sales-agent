            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"status\":\"COLD\"}",
        "options": {}
      },
      "id": "node-mark-expired-leads",
      "name": "Mark Expired Leads COLD",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1600, 500]
    },
    {
      "parameters": {
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/leads?id=in.({{ $('Calculate Updates').first().json.coldLeadIds.join(',') }})",
        "method": "PATCH",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $vars.SUPABASE_ANON_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $vars.SUPABASE_SERVICE_ROLE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"status\":\"COLD\"}",
        "options": {}
      },
      "id": "node-mark-cold-leads",
      "name": "Mark Cold Sequences COLD",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1820, 500]
    },
    {
      "parameters": {
        "jsCode": "const upd = $('Calculate Updates').first().json;\nreturn [{\n  json: {\n    success: true,\n    action: 'update',\n    pendingMessages: upd.pendingCount,\n    expiredMarked: upd.expiredCount,\n    coldMarked: upd.coldCount\n  }\n}];"
      },
      "id": "node-update-done",
      "name": "Update Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2040, 500]
    },

    {
      "parameters": {
        "jsCode": "// Trigger import via sub-execution context\n// In n8n, 'full' simply re-fires import branch then generate then update\n// Here we return a signal to the webhook that the full flow started\nreturn [{json:{action:'full',status:'started',message:'Import → Generate → Update sequence initiated. Run each action separately or use n8n sub-workflows for chaining.'}}];"
      },
      "id": "node-full",
      "name": "Full Mode",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 700]
    },
    {
      "parameters": {
        "jsCode": "return [{json:{error:true,message:`Unknown action: ${$json.body?.action}. Use: import | generate | update | full`}}];"
      },
      "id": "node-fallback",
      "name": "Unknown Action",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 900]
    },

    {
      "parameters": {
        "jsCode": "// Merge all branch results into a single response\nconst data = $input.all().map(i=>i.json);\nreturn [{json:{timestamp:new Date().toISOString(),results:data}}];"
      },
      "id": "node-respond",
      "name": "Respond",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3600, 300]
    }
