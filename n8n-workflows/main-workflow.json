        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"lead_id\":\"{{ $('Parse Analysis').item.json.lead_id }}\",\"current_step\":0,\"next_action\":\"SEND_CONNECTION\",\"next_action_date\":\"{{ $now.toISODate() }}\"}",
        "options": {}
