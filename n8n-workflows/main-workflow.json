        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/outreach?current_step=eq.4&step4_sent_at=not.is.null&step4_sent_at=lt.{{ DateTime.now().minus({days:14}).toISO() }}&next_action=neq.COMPLETED&select=id,lead_id",
        "sendHeaders": true,
