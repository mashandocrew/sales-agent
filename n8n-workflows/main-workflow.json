      "id": "node-get-cold",
      "name": "Get Cold Sequences",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1160, 500]
    },
    {
      "parameters": {
        "jsCode": "const pending  = $('Get Pending Outreach').first().json;\nconst expired  = $('Get Expired Connections').first().json;\nconst cold     = $('Get Cold Sequences').first().json;\n\nconst STEP_MAP = {SEND_STEP_2:2,SEND_STEP_3:3,SEND_STEP_4:4};\nconst pendingList = Array.isArray(pending) ? pending.filter(o=>STEP_MAP[o.next_action]) : [];\nconst expiredList = Array.isArray(expired) ? expired : [];\nconst coldList    = Array.isArray(cold)    ? cold    : [];\n\nreturn [{\n  json: {\n    pending: pendingList,\n    pendingCount: pendingList.length,\n    expired: expiredList,\n    expiredCount: expiredList.length,\n    cold: coldList,\n    coldCount: coldList.length,\n    expiredLeadIds: expiredList.map(o=>o.lead_id),\n    expiredOutreachIds: expiredList.map(o=>o.id),\n    coldLeadIds: coldList.map(o=>o.lead_id),\n    coldOutreachIds: coldList.map(o=>o.id)\n  }\n}];"
      },
      "id": "node-calc-updates",
      "name": "Calculate Updates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1380, 500]
    },
    {
      "parameters": {
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/leads?id=in.({{ $json.expiredLeadIds.join(',') }})",
        "method": "PATCH",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $vars.SUPABASE_ANON_KEY }}" },
