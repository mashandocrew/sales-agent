    {
      "parameters": {
        "url": "=https://docs.google.com/spreadsheets/d/{{ $vars.SHEET_ID }}/gviz/tq?tqx=out:csv",
        "options": {}
      },
      "id": "node-fetch-sheet",
      "name": "Fetch Google Sheet",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 100]
    },
    {
      "parameters": {
        "jsCode": "// Parse CSV and build lead objects\nconst text = $input.first().json.data;\nconst lines = text.replace(/\\r\\n/g,'\\n').replace(/\\r/g,'\\n').split('\\n').filter(l=>l.trim());\n\nfunction parseCSVLine(line) {\n  const fields=[];let i=0;\n  while(i<line.length){\n    if(line[i]==='\"'){let v='';i++;\n      while(i<line.length){if(line[i]==='\\'\"\\'' && line[i+1]==='\"'){v+='\"';i+=2;}else if(line[i]==='\"'){i++;break;}else v+=line[i++];}\n      fields.push(v);if(line[i]===',')i++;\n    }else{const e=line.indexOf(',',i);if(e<0){fields.push(line.slice(i).trim());break;}fields.push(line.slice(i,e).trim());i=e+1;}\n  }\n  return fields;\n}\n\nif(lines.length<2) return [{json:{leads:[],skipped:0,imported:0}}];\n\nconst header=parseCSVLine(lines[0]).map(h=>h.trim());\nconst dataRows=lines.slice(1);\n\n// Fetch existing URLs from Supabase to deduplicate\n// (We'll do this in a separate HTTP Request node)\nconst leads=dataRows.map(line=>{\n  const row=parseCSVLine(line);\n  const obj={};\n  header.forEach((h,i)=>{obj[h]=row[i]?.trim()||null;});\n  return obj;\n}).filter(r=>r.first_name&&r.last_name&&r.linkedin_url);\n\nreturn [{json:{leads,count:leads.length}}];"
      },
      "id": "node-parse-csv",
      "name": "Parse CSV",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [940, 100]
    },
    {
      "parameters": {
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/leads?select=linkedin_url",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $vars.SUPABASE_ANON_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $vars.SUPABASE_SERVICE_ROLE_KEY }}" }
          ]
        },
        "options": {}
      },
      "id": "node-get-existing-urls",
      "name": "Get Existing URLs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1160, 100]
    },
    {
      "parameters": {
        "jsCode": "const parsed = $('Parse CSV').first().json;\nconst existing = $input.all().map(i=>i.json.linkedin_url?.toLowerCase()).filter(Boolean);\nconst existSet = new Set(existing);\n\nconst newLeads = parsed.leads\n  .filter(l => !existSet.has(l.linkedin_url?.toLowerCase()))\n  .map(l => ({\n    first_name:    l.first_name,\n    last_name:     l.last_name,\n    title:         l.title || null,\n    company:       l.company || null,\n    industry:      l.industry || null,\n    location:      l.location || null,\n    linkedin_url:  l.linkedin_url,\n    website:       l.website || null,\n    employee_count:l.employee_count ? parseInt(l.employee_count)||null : null,\n    status:        'NEW',\n    source:        'n8n_sheet',\n    sales_stage:   'PROSPECTADO'\n  }));\n\nreturn [{json:{newLeads,count:newLeads.length,skipped:parsed.leads.length-newLeads.length}}];"
      },
      "id": "node-dedup",
      "name": "Deduplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
