      "id": "node-create-outreach",
      "name": "Create Outreach",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2040, 300]
    },
    {
      "parameters": {
        "jsCode": "// Build the 4 message prompts using lead + analysis data\nconst analysis = $('Parse Analysis').item.json;\nconst outreach = $input.first().json[0];\n\nconst lead = {\n  ...analysis,\n  outreach_id: outreach.id\n};\n\nconst steps = [\n  {\n    step_number: 1,\n    message_type: 'connection_note',\n    max_chars: 300,\n    prompt: `Escribí una nota de conexión de LinkedIn en español para:\\n${lead.first_name} ${lead.last_name}, ${lead.title??'profesional'} en ${lead.company??'su empresa'} (${lead.industry??''}, ${lead.location??''}).\\n\\nCONTEXTO: ${lead.relevance_hook}\\n\\nREGLAS ESTRICTAS:\\n- MÁXIMO 300 caracteres\\n- NO menciones Pip, WhatsApp, automatización, ventas, ni tu empresa\\n- NO uses frases de presentación genéricas\\n- SÍ mencioná algo específico de ${lead.company??'su empresa'}\\n- Usá el nombre: ${lead.first_name}\\n\\nRespondé SOLO con el texto.`\n  },\n  {\n    step_number: 2,\n    message_type: 'linkedin_message',\n    max_chars: 500,\n    prompt: `Escribí un mensaje de LinkedIn en español para ${lead.first_name} ${lead.last_name}, ${lead.title??'profesional'} en ${lead.company??'su empresa'}.\\nYa aceptó tu conexión. Pain point: ${lead.pain_point}. Gancho: ${lead.relevance_hook}.\\nProducto: Pip (soypip.com) automatiza WhatsApp Business.\\nREGLAS: máx 500 chars, agradecé conexión, mencioná dato concreto de su industria, NO pidas reunión.\\nRespondé SOLO con el texto.`\n  },\n  {\n    step_number: 3,\n    message_type: 'linkedin_message',\n    max_chars: 400,\n    prompt: `Escribí un mensaje de LinkedIn en español para ${lead.first_name} de ${lead.company??'su empresa'}.\\nOfrecé enviar video de 30 seg mostrando automatización de WhatsApp en ${lead.industry??'su industria'}.\\nREGLAS: máx 400 chars, pregunta cerrada sí/no, no insistente.\\nRespondé SOLO con el texto.`\n  },\n  {\n    step_number: 4,\n    message_type: 'linkedin_message',\n    max_chars: 250,\n    prompt: `Escribí mensaje de cierre de LinkedIn en español para ${lead.first_name} de ${lead.company??'su empresa'}.\\nREGLAS: máx 250 chars, breve, respetuoso, dejá la puerta abierta.\\nRespondé SOLO con el texto.`\n  }\n];\n\nreturn steps.map(s => ({json:{...s, lead_id: lead.lead_id, outreach_id: lead.outreach_id}}));"
      },
