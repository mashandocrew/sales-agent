    {
      "parameters": {
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $vars.GROQ_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"temperature\": 0.3,\n  \"max_tokens\": 300,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Sos un analista de ventas B2B experto en el mercado hispano de Estados Unidos y LATAM.\\nAnalizá este prospecto para venderle Pip (soypip.com), una plataforma de automatización de WhatsApp Business.\\n\\nProducto Pip: Chatbot con IA para WhatsApp, CRM conversacional, envíos masivos, plantillas con botones, etiquetas inteligentes, derivaciones automáticas, chat interno, API/Webhooks, analytics.\\n\\nProspecto:\\n- Nombre: {{ $json.first_name }} {{ $json.last_name }}\\n- Cargo: {{ $json.title ?? 'desconocido' }}\\n- Empresa: {{ $json.company ?? 'desconocida' }}\\n- Industria: {{ $json.industry ?? 'desconocida' }}\\n- Ubicación: {{ $json.location ?? 'desconocida' }}\\n- Empleados: {{ $json.employee_count ?? 'desconocido' }}\\n\\nRespondé ÚNICAMENTE con JSON válido. Sin markdown, sin backticks:\\n{\\n  \\\"pain_point\\\": \\\"NO_WHATSAPP_AUTO | CHATBOT_DEFICIENTE | SIN_WHATSAPP | SOPORTE_MANUAL | CRECIMIENTO_SIN_ESCALA\\\",\\n  \\\"relevance_hook\\\": \\\"una oración corta y específica sobre por qué este prospecto necesita automatizar WhatsApp\\\",\\n  \\\"priority_score\\\": 1,\\n  \\\"reasoning\\\": \\\"breve\\\"\\n}\"\n  }]\n}",
        "options": {}
      },
      "id": "node-groq-analysis",
      "name": "Groq: Analyze Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1380, 300]
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Loop Leads').item.json;\nconst raw = $input.first().json.choices[0].message.content.trim();\nlet analysis;\ntry {\n  analysis = JSON.parse(raw.replace(/```json|```/g,'').trim());\n} catch(e) {\n  analysis = {pain_point:'SOPORTE_MANUAL',relevance_hook:'Necesita automatizar WhatsApp',priority_score:5,reasoning:'parse error'};\n}\nreturn [{\n  json: {\n    lead_id: lead.id,\n    first_name: lead.first_name,\n    last_name: lead.last_name,\n    title: lead.title,\n    company: lead.company,\n    industry: lead.industry,\n    location: lead.location,\n    employee_count: lead.employee_count,\n    ...analysis\n  }\n}];"
      },
      "id": "node-parse-analysis",
      "name": "Parse Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1600, 300]
    },
    {
